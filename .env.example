# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Your Weights & Biases username or team name
WANDB_ENTITY=your_wandb_entity_here

# Optional prefix prepended to all wandb project names (e.g. your username or team)
WANDB_PROJECT_PREFIX=MAD

# MuJoCo rendering backend for headless machines (no display).
# Use "egl" (preferred) or "osmesa" (software fallback). Remove on machines with a display.
MUJOCO_GL=egl
